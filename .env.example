CREEM_API_URL=https://api.creem.io/v1
CREEM_WEBHOOK_SECRET=whsec_xxx

# Product IDs from your Creem dashboard. Configure plans in lib/plans.ts.
CREEM_PRODUCT_STARTER=prod_xxx
CREEM_PRODUCT_PRO=prod_xxx
CREEM_PRODUCT_BUSINESS=prod_xxx
CREEM_PRODUCT_CREDITS_PACK=prod_xxx
